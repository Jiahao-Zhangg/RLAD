# Copy to .env.cluster, fill private values, and source it before submitting.
# The real .env.cluster file is ignored by Git.

# With the expected clone at /fsx/gstevenw/testing_alignment_algos/RLAD this
# resolves to /fsx/gstevenw/testing_alignment_algos/RLAD/train/rl automatically.
_RLAD_PROFILE_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
export RLAD_HOME="${RLAD_HOME:-${_RLAD_PROFILE_DIR}}"
export MILES_DIR="${MILES_DIR:-${RLAD_HOME}/miles}"
export RLAD_DATA="${RLAD_DATA:-${RLAD_HOME}/data}"
export RLAD_RUNS="${RLAD_RUNS:-${RLAD_HOME}/runs}"
export RLAD_LOGS="${RLAD_LOGS:-${RLAD_HOME}/logs}"

# P5 Slurm profile. Leave RLAD_ACCOUNT empty if the cluster does not require one.
export RLAD_PARTITION="${RLAD_PARTITION:-ml.p5.48xlarge}"
export RLAD_ACCOUNT="${RLAD_ACCOUNT:-}"
export RLAD_SBATCH_CPUS_PER_TASK="${RLAD_SBATCH_CPUS_PER_TASK:-32}"
export RLAD_SBATCH_MEMORY="${RLAD_SBATCH_MEMORY:-400G}"

# Host Conda environment and shared Hugging Face cache.
export CONDA_BASE="${CONDA_BASE:-/fsx/gstevenw/miniconda3}"
export RLAD_CONDA_ENV="${RLAD_CONDA_ENV:-rlad}"
export HF_HOME="${HF_HOME:-/fsx/gstevenw/testing_alignment_algos/huggingface-cache}"

# Pyxis/enroot image. The file must be built or copied to this location.
export RLAD_CONTAINER="${RLAD_CONTAINER:-/fsx/gstevenw/testing_alignment_algos/images/miles.sqsh}"
export RLAD_CONTAINER_MOUNTS="${RLAD_CONTAINER_MOUNTS:-/fsx:/fsx}"
export RLAD_CONTAINER_MOUNT_HOME="${RLAD_CONTAINER_MOUNT_HOME:-0}"

# Supply secrets only in the ignored .env.cluster file or a secret manager.
# export HF_TOKEN=...
# export WANDB_API_KEY=...

# Post-training publication. The authenticated HF username is used when
# HF_NAMESPACE is empty. Repositories are private unless explicitly changed.
export HF_NAMESPACE="${HF_NAMESPACE:-}"
export HF_REPO_PREFIX="${HF_REPO_PREFIX:-rlad-original}"
export HF_REPO_PRIVATE="${HF_REPO_PRIVATE:-1}"
# Optional exact destinations (defaults are derived from HF_REPO_PREFIX):
# export HF_SFT_DATASET_REPO=my-user/my-sft-data
# export HF_RFT_DATASET_REPO=my-user/my-rft-data
# export HF_SFT_MODEL_REPO=my-user/my-sft-model
# export HF_RFT_MODEL_REPO=my-user/my-rft-model

# The five-metric DeepScaleR-hard comparison is logged to this W&B project.
export WANDB_PROJECT="${WANDB_PROJECT:-repro-paper003-rlad}"
export WANDB_ENTITY="${WANDB_ENTITY:-}"
export WANDB_EVAL_GROUP="${WANDB_EVAL_GROUP:-absgen-rft-eval}"

# Load shared path defaults and the rlad_activate_conda helper.
source "${RLAD_HOME}/jobs/cluster_env.sh"
unset _RLAD_PROFILE_DIR
